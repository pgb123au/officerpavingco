  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free patio paving consultation.</h2>
        <p>Stone samples on-site in your own light. Honest cost-and-care comparison across all four materials.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
