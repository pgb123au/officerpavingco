---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What's the difference between exposed aggregate and stencilled concrete in Officer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Exposed aggregate is real stone — typically a 7-10mm river-stone or granite blend mixed into the concrete, then the top paste is washed off to reveal the stone. The surface is naturally non-slip, lasts 30+ years, and the texture/colour can't fade because it IS the stone. ~$140-$180/m² installed. Stencilled concrete is a printed pattern (brick, slate, cobble) pressed into wet concrete then coloured with oxide stains and sealed. Looks great in year 1 but the sealer needs reapplying every 3-5 years and the colour fades UV. ~$130-$160/m² installed. For an Officer new-build with 30+ year intent, exposed agg is the better long-term call. For a renter / 5-year horizon, stencilled gets the look cheaper." }
    },
    {
      "@type": "Question",
      "name": "How thick should a driveway slab be in Officer's clay soil?",
      "acceptedAnswer": { "@type": "Answer", "text": "Standard residential driveway in Officer (Class M reactive clay): 100mm slab with SL82 mesh reinforcement on 100mm compacted Class 3 crushed-rock base, with 75µm plastic moisture barrier between base and slab. For heavier vehicles (caravan, boat trailer, work ute) or Class H clay (parts of Beaconsfield Upper, Pakenham Upper): 125mm slab with SL92 mesh. The crossover apron (kerb-to-property-line section under council jurisdiction) must be 125mm minimum with SL82 mesh — that's a Cardinia Shire IPWEA spec, not optional." }
    },
    {
      "@type": "Question",
      "name": "Why do Officer driveways crack — and can it be prevented?",
      "acceptedAnswer": { "@type": "Answer", "text": "Three causes, in order of frequency: (1) inadequate base prep — Class M clay heaving against unreinforced slab cracks within 3 years; (2) no control joints — slabs over 6m without cut joints crack randomly; (3) shrinkage cracking — concrete poured in 35°C summer heat without proper curing cracks within weeks. We mitigate all three: 100mm compacted Class 3 base, SL82 mesh + 100mm slab thickness, control joints saw-cut at 4m spacing within 12-24 hours of pour, curing compound applied immediately, hot-weather pours stopped at 32°C or scheduled for early morning. Hairline cracking under 0.3mm is normal in any concrete and doesn't affect performance — wider cracking is a workmanship or design failure." }
    },
    {
      "@type": "Question",
      "name": "Can you do a permeable paving driveway in Officer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — permeable paving (Adbri Permapave, Boral Hydropave or similar) lets stormwater drain through the joints into a deep aggregate sub-base, reducing stormwater runoff onto Council drains. Worth considering for: large driveway areas (50m²+), blocks where the council has stormwater capacity issues, or owners pursuing 6-star sustainability ratings. Cost is ~20% premium over standard segmental paving (~$150-$220/m²) because the sub-base is deeper (300mm vs 100mm) and the bedding is open-graded angular rock not sand. Maintenance is slightly higher — joints need vacuuming every few years to clear silt. Not suitable for very steep driveways (over 1:8) — water runs off before it can infiltrate." }
    },
    {
      "@type": "Question",
      "name": "How long until I can drive on a new concrete driveway?",
      "acceptedAnswer": { "@type": "Answer", "text": "Foot traffic: 24-48 hours. Light vehicle (car, ute): 7 days minimum, 14 days preferred. Heavy vehicle (caravan, boat, truck): 28 days for full design strength. We always pour on a Friday so the slab gets 4-5 weather-flexible days before the homeowner needs the driveway on Monday morning. If you've got two cars and one driveway, talk to us at quote stage — sometimes we can pour in two halves so you've always got access to one bay." }
    },
    {
      "@type": "Question",
      "name": "Does the Cardinia Shire crossover have to be done by a contractor on a council list?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cardinia Shire requires the crossover to be constructed to Council's specification by a contractor experienced with IPWEA-aligned residential pavement work. The Council doesn't maintain a strict pre-approved list (some councils do), but they do inspect every crossover at pour stage and at completion, and they fail jobs that don't meet spec. Costs of a failure: re-pour at contractor's expense, plus delay to driveway-side concrete. We pour to spec the first time — every Officer crossover we've poured in the last 3 years has passed first inspection." }
    }
  ]
};
---
<Layout
  title="Driveway Paving Officer | Exposed Aggregate, Stencilled, Block | (03) 9003 0108"
  description="Driveway paving for Officer, Cardinia Lakes, Beaconsfield, Pakenham — exposed aggregate, stencilled concrete, segmental block paving and full bluestone driveways. Cardinia Shire crossover permit included. AS 3727 compliant."
  canonical="https://officerpavingco.com.au/services/driveway-paving/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Concrete, aggregate, block or stone</span>
      <h1>Driveway paving in <span class="accent">Officer &amp; Cardinia Shire</span>.</h1>
      <p class="hero-sub">
        Standard concrete, exposed aggregate, stencilled, segmental block paving and
        full bluestone driveways. Cardinia Shire crossover permit lodged for you,
        AS 3727 residential-pavement spec, CCAA-aligned exposed-aggregate mix design.
        The driveway that&rsquo;s still flat in year 15.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free site visit</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>The five driveway formats we lay.</h2>
      <div style="max-width: 65rem;">
        <ul>
          <li><strong>Standard concrete</strong> &mdash; broom-finish or trowel-smooth grey concrete with SL82 mesh in a 100mm slab. The default, the cheapest, the longest-lasting if reinforced properly. ~$90&ndash;$130/m&sup2; installed.</li>
          <li><strong>Exposed aggregate</strong> &mdash; 7&ndash;10mm river-stone or granite blend mixed into the concrete, top paste washed off to reveal stone. CCAA-aligned mix design. Real-stone surface, naturally non-slip, won&rsquo;t fade. ~$140&ndash;$180/m&sup2;.</li>
          <li><strong>Stencilled concrete</strong> &mdash; brick, slate or cobble pattern pressed into wet concrete + oxide-stained + sealed. Looks great year 1, needs resealing every 3&ndash;5 years. ~$130&ndash;$160/m&sup2;.</li>
          <li><strong>Segmental block paving</strong> &mdash; Adbri, Boral or Brikmakers block pavers laid over compacted Class 3 base, sand bedded, polymeric-sanded joints, edge restrained. Individual blocks replaceable if damaged. ~$130&ndash;$200/m&sup2;.</li>
          <li><strong>Bluestone or granite pavers</strong> &mdash; large-format natural stone, premium look, holds colour for life. 30+ year horizon. ~$180&ndash;$260/m&sup2;.</li>
        </ul>

        <h3 style="margin-top: 2rem;">Why exposed aggregate dominates Officer new builds.</h3>
        <p>
          Roughly 60% of Officer-estate driveways we&rsquo;ve poured in the last
          three years are exposed aggregate. The reason: it looks like a $200/m&sup2;
          stone driveway at $140&ndash;$180/m&sup2;, the texture means kids and dogs
          don&rsquo;t slip on it after rain, and the surface doesn&rsquo;t need
          re-sealing every few years like stencilled does. The catch is mix design
          and washing window &mdash; cheap exposed agg jobs use the wrong aggregate
          size and wash too late, leaving you with a patchy pebble surface. We
          spec a 7&ndash;10mm river-stone or granite blend from a CCAA-compliant
          supplier and wash within the right working window every time.
        </p>

        <h3 style="margin-top: 2rem;">The Cardinia Shire crossover permit (the bit that trips most owners).</h3>
        <p>
          The strip between the road kerb and your property boundary is council
          jurisdiction. Any work on it &mdash; new crossover, widening single to
          double, replacing a damaged one &mdash; needs a <strong>vehicle crossing
          permit</strong> from Cardinia Shire (~$200&ndash;$350 application fee).
          The crossover slab must be <strong>125mm thick, SL82 mesh, set widths
          to council spec, expansion joints at the kerb</strong>. Council
          inspects at pour and at completion. We lodge the application, book the
          inspections and pour to the IPWEA-aligned spec.
        </p>

        <h3 style="margin-top: 2rem;">Base prep &mdash; the unglamorous bit that matters most.</h3>
        <ul>
          <li><strong>Excavation:</strong> Strip topsoil + 100&ndash;150mm of site clay. Officer clay is reactive (Class M) &mdash; leaving it under the slab causes cracking within 3 years.</li>
          <li><strong>Base course:</strong> 100mm minimum compacted Class 3 crushed rock, compacted to 95% MMDD in 75mm layers. Not 100mm dumped in one pass &mdash; that&rsquo;s not compaction.</li>
          <li><strong>Moisture barrier:</strong> 75&micro;m polyethylene sheet between base and slab. Stops base moisture wicking into concrete and stops slurry losing to base.</li>
          <li><strong>Reinforcement:</strong> SL82 mesh, full top-half cover. SL92 for heavier vehicles or Class H clay sites.</li>
          <li><strong>Control joints:</strong> Saw-cut at 4m spacing within 12&ndash;24 hours of pour. No cut joints = random crack location.</li>
        </ul>

        <h3 style="margin-top: 2rem;">Pricing examples (Officer 2026).</h3>
        <ul>
          <li>60m&sup2; double driveway, standard concrete + crossover: $6,500&ndash;$8,500</li>
          <li>60m&sup2; double driveway, exposed aggregate + crossover: $9,500&ndash;$12,500</li>
          <li>60m&sup2; double driveway, stencilled + crossover: $8,500&ndash;$10,500</li>
          <li>60m&sup2; double driveway, segmental block + crossover: $9,000&ndash;$13,500</li>
          <li>60m&sup2; double driveway, bluestone pavers + crossover: $12,500&ndash;$17,500</li>
        </ul>

        <h3 style="margin-top: 2rem;">Standards we work to.</h3>
        <ul>
          <li><strong>AS 3727 &mdash; Residential pavements:</strong> Slab thickness, base spec, crossfall (1:80 minimum to drain), joint spacing.</li>
          <li><strong>AS 2870 &mdash; Residential slabs on reactive soil:</strong> Soil classification, footing design on reactive clay.</li>
          <li><strong>CCAA &mdash; Cement Concrete &amp; Aggregates Australia:</strong> Mix-design guidance for exposed aggregate, curing, hot-weather pouring.</li>
          <li><strong>Cardinia Shire IPWEA standard drawings:</strong> Crossover thickness, dimensions, expansion-joint location.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Where we work.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/officer/">Officer</a>
        <a class="area-pill" href="/cardinia-lakes/">Cardinia Lakes</a>
        <a class="area-pill" href="/beaconsfield/">Beaconsfield</a>
        <a class="area-pill" href="/pakenham/">Pakenham</a>
        <a class="area-pill" href="/heritage-springs/">Heritage Springs</a>
        <a class="area-pill" href="/cardinia-shire/">All Cardinia Shire</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free driveway quote.</h2>
        <p>Mix-design samples on-site. Cardinia Shire crossover permit lodged with the job.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
