---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which Officer estates are you working in most?",
      "acceptedAnswer": { "@type": "Answer", "text": "Arena Estate (north of Princes Highway), Heritage Springs (central Officer 3809), Timbertop (between Arena and Heritage Springs), and the older Officer South streets around Brunt Road and Tivendale Road. Each estate has its own house-product mix and budget bracket - newer Arena lots are 350-500m² with 4-bedroom builds running $700K-$900K and exposed-aggregate is the default driveway; older Officer South streets sit on 700-1,200m² with 1980s-1990s brick veneers needing replacement of original concrete driveways and patios that have failed on Class M clay." }
    },
    {
      "@type": "Question",
      "name": "Why do new Officer estate driveways crack within a few years?",
      "acceptedAnswer": { "@type": "Answer", "text": "Officer is on Class M reactive clay (AS 2870 mapping). The clay seasonally expands and contracts by 20-40mm between wet winter and dry summer. New-build developer driveways are often poured to minimum spec - 75mm slab, no mesh, no proper base - to hit cost targets. Within 2-4 years the slab cracks at random points as clay heaves underneath. Our standard spec for an Officer driveway is 100mm slab with SL82 mesh on 100mm compacted Class 3 base with moisture barrier and saw-cut control joints at 4m centres. That's 25-30% more material than the budget spec but the slab is flat at year 15." }
    },
    {
      "@type": "Question",
      "name": "What's the typical Officer new-build alfresco paving setup?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most Officer-estate alfresco zones are 18-28m² (8-12 minimum the developer leaves; owners want it doubled). Default 2026 build: bluestone or sandstone pavers in 600×400×30mm format, polymeric-sanded joints, 100mm Class 3 base, 1:80 fall away from house to a grated linear drain at the lawn edge. Cost: $4,500-$8,500 for 20m². Common upgrade is laying the patio level with the alfresco slab (no step) for a flush indoor-outdoor flow - needs careful drainage detailing at the door threshold. Edge restraints (concrete haunch or steel edging) are mandatory or the pavers walk outwards under load over 5-10 years." }
    },
    {
      "@type": "Question",
      "name": "How long until I can drive on a new Officer driveway slab?",
      "acceptedAnswer": { "@type": "Answer", "text": "Foot traffic 24-48 hours, light vehicle 7 days minimum, heavy vehicle (caravan, trailer, boat) 28 days. We typically pour on a Friday so the slab gets the weekend plus a buffer day before working week traffic. If you've got a two-car household and a single driveway, talk to us at quote stage - sometimes we can pour in two halves so you've always got vehicle access to one bay." }
    },
    {
      "@type": "Question",
      "name": "What's the Cardinia Shire crossover situation for an Officer new build?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most new builds in Arena, Heritage Springs and Timbertop have a developer-installed crossover already - built when the estate roads went in. That's fine until you want a wider driveway (single-to-double) or the existing crossover is damaged. New or replacement crossover means a Cardinia Shire vehicle-crossing permit (~$200-$350 fee), 125mm slab thickness, SL82 mesh, set widths per Council's IPWEA-aligned spec. Council inspects at pour and completion. We lodge the permit and pour to spec - we haven't failed a crossover inspection in Officer in 3 years." }
    },
    {
      "@type": "Question",
      "name": "Do you do landscaping as well as paving in Officer?",
      "acceptedAnswer": { "@type": "Answer", "text": "We specialise in paving, stonemasonry, retaining walls and hardscape - the hard surfaces. We don't do soft landscaping (turf, garden beds, planting) ourselves but we coordinate routinely with two Officer landscapers we work alongside. The boundary is clean: we hand over to them at the edge of the paving, levels-correct and drainage-correct, and they take over for soil, turf and planting. One quote, two trades, no coordination headaches." }
    }
  ]
};
---
<Layout
  title="Paving & Stonemasonry Officer | Driveways, Patios, Retaining Walls | (03) 9003 0108"
  description="Paving and stonemasonry for Officer 3809 - new-estate driveways (Arena, Heritage Springs, Timbertop), alfresco patios, engineered retaining walls. Cardinia Shire crossover permits. Class M reactive-clay base spec."
  canonical="https://officerpavingco.com.au/officer/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">Officer 3809 &middot; Arena &middot; Heritage Springs &middot; Timbertop</span>
      <h1>Paving &amp; stonemasonry in <span class="accent">Officer</span>.</h1>
      <p class="hero-sub">
        Officer is one of Victoria&rsquo;s fastest-growing growth-corridor suburbs -
        Arena, Heritage Springs and Timbertop estates filling out alongside older
        Officer South streets. Two markets in one suburb: new-build owners wanting
        exposed-aggregate driveways and bluestone alfresco patios, and 80s/90s
        homeowners replacing failed concrete on Class M clay.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
        <a class="btn btn-ghost" href="/quote/">Book a free site visit</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <span class="section-eyebrow">Why Officer</span>
      <h2>The Officer paving story.</h2>
      <div class="divider"></div>
      <div style="max-width: 65rem;">
        <h3>Estate-driven new-build demand.</h3>
        <p>
          Arena Estate (north of Princes Highway), Heritage Springs (central
          Officer 3809), Timbertop (between the two) and the older Officer South
          streets around Brunt Road and Tivendale Road are the main paving
          markets here. Newer Arena lots are 350-500m&sup2; with $700K-$900K
          4-bedroom builds - exposed-aggregate driveway is the default,
          bluestone or sandstone alfresco patio is the standard upgrade. Older
          Officer South streets sit on 700-1,200m&sup2; with 1980s/1990s
          brick veneers, and the original driveways and patios are reaching
          end-of-life on the reactive clay.
        </p>

        <h3 style="margin-top: 2rem;">Class M reactive clay - why proper base prep is non-negotiable.</h3>
        <p>
          Officer sits on Class M reactive clay (AS 2870 mapping). Seasonal
          swell/shrink moves 20-40mm between wet winter and dry summer.
          New-build developer driveways often poured to minimum spec (75mm slab,
          no mesh, no proper base) crack within 2-4 years. Our standard
          spec: <strong>100mm slab, SL82 mesh, 100mm compacted Class 3 base,
          moisture barrier, saw-cut control joints at 4m centres</strong>. That&rsquo;s
          25-30% more material than the budget spec - the slab is
          still flat at year 15.
        </p>

        <h3 style="margin-top: 2rem;">Cardinia Shire crossover permits.</h3>
        <p>
          Most new builds in Arena, Heritage Springs and Timbertop have a
          developer-installed crossover - built when the estate roads
          went in. Widening single-to-double or replacing a damaged crossover
          needs a fresh Cardinia Shire vehicle-crossing permit (~$200-$350),
          a 125mm slab with SL82 mesh, set widths per Council&rsquo;s
          IPWEA-aligned spec. Council inspects at pour and at completion. We
          lodge the application, book inspections, pour to spec.
        </p>

        <h3 style="margin-top: 2rem;">Typical Officer jobs.</h3>
        <ul>
          <li>60m&sup2; exposed-aggregate driveway + Cardinia Shire crossover (new build): $9,500-$13,500</li>
          <li>25m&sup2; bluestone alfresco patio + grated linear drain (Arena lot): $7,500-$11,500</li>
          <li>Stencilled concrete driveway replacement (older Officer South 1990s brick veneer): $8,500-$11,500</li>
          <li>Engineered segmental block retaining wall + paved entertaining area (sloping Heritage Springs lot): $15,000-$28,000</li>
          <li>Pool surround bluestone + glass-fence integration (Timbertop new pool): $10,500-$15,500</li>
        </ul>

        <h3 style="margin-top: 2rem;">What we don&rsquo;t do (so you know who to call).</h3>
        <p>
          We don&rsquo;t do soft landscaping (turf, garden beds, planting),
          fencing or carpentry framing. We coordinate with two Officer landscapers
          and a separate carpenter regularly - the handover from
          our paving to their work is clean (levels right, drainage right).
          One conversation at quote stage gets the whole package coordinated.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="section-inner">
      <h2>Other service areas.</h2>
      <div class="areas-grid">
        <a class="area-pill" href="/cardinia-lakes/">Cardinia Lakes</a>
        <a class="area-pill" href="/beaconsfield/">Beaconsfield</a>
        <a class="area-pill" href="/pakenham/">Pakenham</a>
        <a class="area-pill" href="/heritage-springs/">Heritage Springs</a>
        <a class="area-pill" href="/cardinia-shire/">All Cardinia Shire</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Free Officer paving quote.</h2>
        <p>Material samples on-site. Class M clay base spec done right. Cardinia Shire crossover permit lodged.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Book online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
